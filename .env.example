# === Telegram ===
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_SECRET=random_secret_string
MINI_APP_URL=https://miniy.yumoff.site

# === Database ===
DATABASE_URL=postgresql://yumbot:password@localhost:5432/yumbot

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_SECRET=your_very_long_random_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# === Remnawave Panel ===
REMNAWAVE_URL=https://your-remnawave-panel.com
REMNAWAVE_TOKEN=your_remnawave_api_token

# === Remnawave defaults for new users ===
REMNAWAVE_DEFAULT_TRAFFIC_GB=100
REMNAWAVE_DEFAULT_DAYS=30
REMNAWAVE_DEFAULT_DEVICE_LIMIT=5
REMNAWAVE_SQUAD_UUID=your_squad_uuid_here

# === Stars exchange rate (kopeks per star) ===
STARS_RATE_KOPEKS=200

# === Domains ===
API_URL=https://api.yumoff.site
MINI_APP_DOMAIN=miniy.yumoff.site
WEB_DOMAIN=lk.yumoff.site

# === Node env ===
NODE_ENV=production
PORT=3000

# === Admin Telegram IDs (comma separated) ===
ADMIN_IDS=924201523
